<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bordo_clarito"
    android:fillViewport="true"
    tools:context=".ui.inmuebles.InmuebleDetalleFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="280dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/ivDetalleImagen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="Imagen del inmueble" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvDetalleDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dirección"
                    android:textColor="@color/bordo_oscuro"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetallePrecio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="$ 0.00"
                    android:textColor="#B71C1C"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#D98880" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="4">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uso:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037"
                        android:padding="6dp"/>
                    <TextView
                        android:id="@+id/tvDetalleUso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="16sp"
                        android:padding="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037"
                        android:padding="6dp"/>
                    <TextView
                        android:id="@+id/tvDetalleTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="16sp"
                        android:padding="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ambientes:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037"
                        android:padding="6dp"/>
                    <TextView
                        android:id="@+id/tvDetalleAmbientes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:padding="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Superficie:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037"
                        android:padding="6dp"/>
                    <TextView
                        android:id="@+id/tvDetalleSuperficie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 m²"
                        android:textSize="16sp"
                        android:padding="6dp"/>

                </GridLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="#D98880" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#5D4037"/>

                    <CheckBox
                        android:id="@+id/cbDetalleDisponible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Disponible"
                        android:enabled="false"
                        android:buttonTint="@color/bordo_oscuro"
                        android:textColor="#5D4037"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Volver a la lista"
            android:textSize="16sp"
            app:backgroundTint="@color/bordo_oscuro"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>
</ScrollView>